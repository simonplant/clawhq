{
  "name": "clawhq",
  "version": "0.1.0",
  "description": "Control panel for OpenClaw agents",
  "type": "module",
  "main": "./dist/cli/index.js",
  "exports": {
    ".": "./dist/cli/index.js"
  },
  "bin": {
    "clawhq": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "configs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build && npm run lint && npm run test",
    "prepack": "npm run build"
  },
  "keywords": [
    "openclaw",
    "ai",
    "agent",
    "control-panel",
    "docker",
    "security",
    "self-hosted"
  ],
  "author": "Simon Weniger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clawhq/clawhq.git"
  },
  "homepage": "https://clawhq.com",
  "bugs": {
    "url": "https://github.com/clawhq/clawhq/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "hono": "^4.12.8",
    "ora": "^9.3.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-plugin-import-x": "^4.16.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0",
    "ws": "^8.19.0"
  }
}
