#!/usr/bin/env python3
"""risk-governor — hard constraint enforcement for all trades.

The LLM cannot override this. Every trade must pass check before execution.

Commands:
  risk-governor check <side> <qty> <symbol> --price N [--account A] [--sector S] [--loop L] [--json]
  risk-governor status [--json]
  risk-governor limits

Examples:
  risk-governor check buy 20 NVDA --price 190 --account tos --sector tech
  risk-governor check buy 2 /MES --price 7020 --account tos --loop session
  risk-governor check buy 50 SPY --price 520 --account ira --loop swing
  risk-governor status

Exit codes: 0=APPROVED/REDUCED, 1=BLOCKED, 2=ERROR
"""
import os
import sys

MARKETS_DIR = os.path.join(os.path.dirname(os.path.abspath(__file__)), "markets")
os.environ["MARKETS_DIR"] = MARKETS_DIR
sys.path.insert(0, MARKETS_DIR)

from risk_governor import main
main()
