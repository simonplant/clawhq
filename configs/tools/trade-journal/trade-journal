#!/usr/bin/env python3
"""trade-journal — trade tracker across three accounts (tos, ira, tradier).

Tracks positions and P&L for:
  tos     — $100K ThinkOrSwim (Simon executes, full capability)
  ira     — $100K Fidelity IRA (Simon executes, long-only)
  tradier — $3K Tradier (Clawdius executes, alert-only)

Usage: trade-journal <command> [args]

Commands:
  init                                    — initialize portfolio state
  log <account> <side> <qty> <symbol>     — log a trade (--price, --notes, --execute)
  close <account> <symbol>                — close position (--qty, --price, --notes, --execute)
  mark                                    — EOD mark-to-market all positions
  summary [account]                       — P&L summary
  compare                                 — account comparison vs SPY
  positions [account]                     — open positions
  reconcile                               — reconcile vs Tradier positions
  halt <account> <reason>                 — halt trading for an account
  unhalt <account>                        — resume trading

Options (for log/close):
  --price N       override auto-quote
  --notes '...'   trade rationale
  --execute       also place the order on Tradier
  --qty N         partial close (close only)

Environment:
  CRED_PROXY_URL — credential proxy base URL (required)
"""

import json
import os
import subprocess
import sys
import urllib.request
from datetime import datetime
from pathlib import Path

# --- Config ---

WORKSPACE = Path(os.environ.get("HOME", "/home/node")) / ".openclaw" / "workspace"
JOURNAL = WORKSPACE / "trade-journal.json"
MARKETS = WORKSPACE / "markets"
CONFIG_PATH = MARKETS / "CONFIG.json"
STATE_PATH = MARKETS / "STATE.json"
PROXY = os.environ.get("CRED_PROXY_URL", "")

ACCOUNT_IDS = ("tos", "ira", "tradier")


# --- I/O ---

def _load(path, default=None):
    return json.loads(path.read_text()) if path.exists() else default


def _save(path, data):
    path.write_text(json.dumps(data, indent=2) + "\n")


def _state():
    s = _load(STATE_PATH)
    if not s:
        _die("Portfolio not initialized. Run: trade-journal init")
    # Schema validation: positions must be a dict keyed by symbol.
    # Older state files (or hand-edits) sometimes have positions as a list,
    # which crashes every account-walking command with AttributeError.
    accts = s.get("accounts", {})
    if not isinstance(accts, dict):
        _die(f"Corrupt state: accounts must be a dict, got {type(accts).__name__}. "
             "Back up STATE.json and run: trade-journal init --force")
    for acct_id, acct in accts.items():
        positions = acct.get("positions")
        if not isinstance(positions, dict):
            _die(f"Corrupt state: accounts.{acct_id}.positions must be a dict, "
                 f"got {type(positions).__name__}. This is schema drift from an "
                 "older version. Back up STATE.json and run: trade-journal init --force")
    return s


def _config():
    return _load(CONFIG_PATH, {})


def _journal():
    return _load(JOURNAL, {"trades": []})


# --- API ---

def _api_get(url):
    """GET from credential proxy. Returns parsed JSON or None."""
    if not PROXY:
        return None
    try:
        resp = urllib.request.urlopen(f"{PROXY}{url}", timeout=15)
        return json.loads(resp.read())
    except Exception:
        return None


def _quote(symbol):
    """Current price via Tradier quotes API."""
    data = _api_get(f"/tradier/v1/markets/quotes?symbols={symbol}")
    if data:
        quote = data.get("quotes", {}).get("quote")
        if isinstance(quote, list):
            quote = quote[0] if quote else None
        if quote:
            return quote.get("last") or quote.get("close")
    return None


def _tradier_positions():
    """All Tradier positions as list of dicts."""
    account_id = os.environ.get("TRADIER_ACCOUNT_ID", "")
    if not account_id:
        return []
    data = _api_get(f"/tradier/v1/accounts/{account_id}/positions")
    if not data:
        return []
    positions = data.get("positions", {}).get("position")
    if positions is None:
        return []
    if isinstance(positions, dict):
        positions = [positions]
    result = []
    for p in positions:
        qty = p.get("quantity", 0)
        result.append({
            "symbol": p.get("symbol", ""),
            "qty": str(abs(qty)),
            "side": "short" if qty < 0 else "long",
        })
    return result


# --- Formatting ---

def _money(v):
    return f"-${abs(v):,.2f}" if v < 0 else f"${v:,.2f}"


def _pct(v):
    return f"+{v:.2f}%" if v >= 0 else f"{v:.2f}%"


def _die(msg):
    print(f"Error: {msg}", file=sys.stderr)
    sys.exit(1)


def _trade_id(journal):
    today = datetime.now().strftime("%Y-%m-%d")
    n = sum(1 for t in journal["trades"] if t["id"].startswith(today))
    return f"{today}-{n + 1:03d}"


def _account_exposure(acct):
    return sum(
        p["qty"] * p.get("current_price", p["avg_cost"])
        for p in acct["positions"].values()
    )


def _parse_opts(args, start=0):
    """Parse --price, --notes, --execute, --qty from args list."""
    opts = {"price": None, "notes": "", "execute": False, "qty": None}
    i = start
    while i < len(args):
        if args[i] == "--price" and i + 1 < len(args):
            opts["price"] = float(args[i + 1]); i += 2
        elif args[i] == "--notes" and i + 1 < len(args):
            opts["notes"] = args[i + 1]; i += 2
        elif args[i] == "--execute":
            opts["execute"] = True; i += 1
        elif args[i] == "--qty" and i + 1 < len(args):
            opts["qty"] = int(args[i + 1]); i += 2
        else:
            i += 1
    return opts


def _get_constraints(account_id):
    """Get risk constraints for an account from CONFIG.json."""
    config = _config()
    acct_config = config.get("accounts", {}).get(account_id, {})
    constraints = acct_config.get("constraints", {})
    return {
        "max_position_pct": constraints.get("max_position_pct", 15.0) / 100,
        "max_exposure_pct": constraints.get("max_total_exposure_pct", 60.0) / 100,
    }


# --- Commands ---

def cmd_init(args):
    if STATE_PATH.exists() and "--force" not in args:
        _die("Already initialized. Use --force to reset.")

    config = _config()
    spy = _quote("SPY")

    state = {
        "version": 2,
        "updated_at": datetime.now().isoformat(),
        "inception": datetime.now().strftime("%Y-%m-%d"),
        "accounts": {},
        "risk_snapshot": {
            "total_exposure_pct": 0.0,
            "long_exposure_pct": 0.0,
            "short_exposure_pct": 0.0,
            "largest_position_pct": 0.0,
            "sector_concentration": {},
            "daily_realized_pnl": 0.0,
            "daily_unrealized_pnl": 0.0,
            "high_water_mark": 0.0,
            "drawdown_from_hwm_pct": 0.0,
        },
        "spy_inception_price": spy,
        "last_mark": None,
    }

    total = 0.0
    for acct_id in ACCOUNT_IDS:
        acct_config = config.get("accounts", {}).get(acct_id, {})
        balance = acct_config.get("balance", 0)
        total += balance
        state["accounts"][acct_id] = {
            "name": acct_config.get("name", acct_id),
            "balance": balance,
            "cash": balance,
            "positions": {},
            "realized_pnl": 0.0,
            "halted": False,
            "halt_reason": None,
        }

    state["risk_snapshot"]["high_water_mark"] = total
    _save(STATE_PATH, state)

    if not JOURNAL.exists():
        _save(JOURNAL, {"trades": []})

    print(f"Portfolio initialized: ${total:,.2f} across {len(ACCOUNT_IDS)} accounts")
    for acct_id in ACCOUNT_IDS:
        acct = state["accounts"][acct_id]
        print(f"  {acct_id}: {acct['name']} — {_money(acct['balance'])}")
    if spy:
        print(f"SPY at inception: ${spy:.2f}")


def cmd_log(args):
    if len(args) < 4:
        _die("Usage: trade-journal log <account> <side> <qty> <symbol> [--price N] [--notes '...'] [--execute]")

    state = _state()
    account = args[0].lower()
    side = args[1].lower()
    qty = int(args[2])
    symbol = args[3].upper()
    opts = _parse_opts(args, 4)

    if account not in state["accounts"]:
        _die(f"Unknown account '{account}'. Use: {', '.join(ACCOUNT_IDS)}")
    if side not in ("buy", "sell"):
        _die("Side must be 'buy' or 'sell'.")

    acct = state["accounts"][account]
    if acct["halted"]:
        _die(f"Account {account} halted: {acct['halt_reason']}")

    price = opts["price"]
    if price is None:
        price = _quote(symbol)
        if price is None:
            _die(f"No quote for {symbol}. Use --price to specify.")

    notional = qty * price
    balance = acct["balance"]
    constraints = _get_constraints(account)

    # Constraint: max position size
    max_pos = constraints["max_position_pct"]
    if notional > balance * max_pos:
        _die(f"Position {_money(notional)} exceeds {max_pos*100:.0f}% of {account} ({_money(balance * max_pos)})")

    # Block sell if holding a long (use 'close' instead)
    if side == "sell" and symbol in acct["positions"] and acct["positions"][symbol]["side"] == "long":
        _die(f"{symbol} is LONG in {account} — use 'trade-journal close' to exit, not 'log sell'")

    # Constraint: max exposure
    max_exp = constraints["max_exposure_pct"]
    exposure = _account_exposure(acct)
    if (exposure + notional) > balance * max_exp:
        _die(f"Exposure {_money(exposure + notional)} exceeds {max_exp*100:.0f}% of {account} ({_money(balance * max_exp)})")

    if side == "buy" and notional > acct["cash"]:
        _die(f"Insufficient cash: need {_money(notional)}, have {_money(acct['cash'])}")

    # Append to journal
    journal = _journal()
    tid = _trade_id(journal)
    journal["trades"].append({
        "id": tid,
        "timestamp": datetime.now().isoformat(),
        "account": account,
        "action": "open",
        "side": side,
        "symbol": symbol,
        "qty": qty,
        "price": round(price, 4),
        "notional": round(notional, 2),
        "notes": opts["notes"],
    })
    _save(JOURNAL, journal)

    # Update portfolio state
    if side == "buy":
        acct["cash"] = round(acct["cash"] - notional, 2)
        if symbol in acct["positions"]:
            p = acct["positions"][symbol]
            old_notional = p["qty"] * p["avg_cost"]
            p["qty"] += qty
            p["avg_cost"] = round((old_notional + notional) / p["qty"], 4)
            p["current_price"] = price
        else:
            acct["positions"][symbol] = {
                "qty": qty, "avg_cost": round(price, 4),
                "current_price": price, "side": "long",
            }
    else:  # sell (short)
        acct["cash"] = round(acct["cash"] + notional, 2)
        if symbol in acct["positions"] and acct["positions"][symbol]["side"] == "short":
            p = acct["positions"][symbol]
            old_notional = p["qty"] * p["avg_cost"]
            p["qty"] += qty
            p["avg_cost"] = round((old_notional + notional) / p["qty"], 4)
            p["current_price"] = price
        else:
            acct["positions"][symbol] = {
                "qty": qty, "avg_cost": round(price, 4),
                "current_price": price, "side": "short",
            }
    _save(STATE_PATH, state)

    # Execute on Tradier if requested
    if opts["execute"]:
        r = subprocess.run(
            ["tradier", "orders", "place", side, str(qty), symbol, "market"],
            capture_output=True, text=True, timeout=15,
        )
        if r.returncode == 0:
            print(f"Tradier: {r.stdout.strip()}")
        else:
            print(f"Tradier FAILED: {r.stderr.strip()}")

    exposure = _account_exposure(acct)
    print(f"[{tid}] {account}: {side} {qty} {symbol} @ ${price:.2f} ({_money(notional)})")
    print(f"  Cash: {_money(acct['cash'])}  Exposure: {_pct(exposure / balance * 100)}")


def cmd_close(args):
    if len(args) < 2:
        _die("Usage: trade-journal close <account> <symbol> [--qty N] [--price N] [--notes '...'] [--execute]")

    state = _state()
    account = args[0].lower()
    symbol = args[1].upper()
    opts = _parse_opts(args, 2)

    if account not in state["accounts"]:
        _die(f"Unknown account '{account}'.")

    acct = state["accounts"][account]
    if symbol not in acct["positions"]:
        _die(f"No {symbol} position in {account}.")

    pos = acct["positions"][symbol]
    close_qty = opts["qty"] or pos["qty"]
    if close_qty > pos["qty"]:
        _die(f"Can't close {close_qty} — only hold {pos['qty']}.")

    price = opts["price"]
    if price is None:
        price = _quote(symbol)
        if price is None:
            _die(f"No quote for {symbol}. Use --price.")

    notional = close_qty * price

    # Calculate P&L
    if pos["side"] == "long":
        pnl = (price - pos["avg_cost"]) * close_qty
        close_side = "sell"
    else:
        pnl = (pos["avg_cost"] - price) * close_qty
        close_side = "buy"

    # Append to journal
    journal = _journal()
    tid = _trade_id(journal)
    journal["trades"].append({
        "id": tid,
        "timestamp": datetime.now().isoformat(),
        "account": account,
        "action": "close",
        "side": close_side,
        "symbol": symbol,
        "qty": close_qty,
        "price": round(price, 4),
        "notional": round(notional, 2),
        "pnl": round(pnl, 2),
        "notes": opts["notes"],
    })
    _save(JOURNAL, journal)

    # Update state
    if pos["side"] == "long":
        acct["cash"] = round(acct["cash"] + notional, 2)
    else:
        acct["cash"] = round(acct["cash"] - notional, 2)

    acct["realized_pnl"] = round(acct.get("realized_pnl", 0) + pnl, 2)

    if close_qty >= pos["qty"]:
        del acct["positions"][symbol]
    else:
        pos["qty"] -= close_qty

    _save(STATE_PATH, state)

    # Execute on Tradier
    if opts["execute"]:
        r = subprocess.run(
            ["tradier", "orders", "place", close_side, str(close_qty), symbol, "market"],
            capture_output=True, text=True, timeout=15,
        )
        if r.returncode == 0:
            print(f"Tradier: {r.stdout.strip()}")
        else:
            print(f"Tradier FAILED: {r.stderr.strip()}")

    print(f"[{tid}] {account}: close {close_qty} {symbol} @ ${price:.2f} — P&L: {_money(pnl)}")
    print(f"  Cash: {_money(acct['cash'])}  Realized: {_money(acct['realized_pnl'])}")


def cmd_mark(args):
    state = _state()
    symbols = set()
    for acct in state["accounts"].values():
        symbols.update(acct["positions"].keys())

    if not symbols:
        print("No positions to mark.")
        return

    prices = {}
    failed = []
    for sym in sorted(symbols):
        p = _quote(sym)
        if p is not None:
            prices[sym] = p
        else:
            failed.append(sym)

    for acct in state["accounts"].values():
        for sym, pos in acct["positions"].items():
            if sym in prices:
                pos["current_price"] = prices[sym]

    state["last_mark"] = datetime.now().isoformat()
    _save(STATE_PATH, state)

    print(f"Marked {len(prices)} positions")
    if failed:
        print(f"  No quote: {', '.join(failed)}")
    print()
    _print_summary(state)


def cmd_summary(args):
    state = _state()
    acct_filter = args[0].lower() if args else None
    if acct_filter and acct_filter not in state["accounts"]:
        _die(f"Unknown account '{acct_filter}'. Use: {', '.join(ACCOUNT_IDS)}")
    _print_summary(state, acct_filter)


def _print_summary(state, acct_filter=None):
    total_nav = 0

    for acct_id in ACCOUNT_IDS:
        if acct_id not in state["accounts"]:
            continue
        acct = state["accounts"][acct_id]
        if acct_filter and acct_id != acct_filter:
            continue

        unrealized = 0
        for pos in acct["positions"].values():
            cp = pos.get("current_price", pos["avg_cost"])
            if pos["side"] == "long":
                unrealized += (cp - pos["avg_cost"]) * pos["qty"]
            else:
                unrealized += (pos["avg_cost"] - cp) * pos["qty"]

        realized = acct.get("realized_pnl", 0)
        exposure = _account_exposure(acct)
        nav = acct["cash"] + exposure
        total_nav += nav
        balance = acct["balance"]
        ret = (nav - balance) / balance * 100 if balance else 0

        halted = " [HALTED]" if acct.get("halted") else ""
        print(f"=== {acct_id}: {acct['name']}{halted} ===")
        print(f"  NAV:        {_money(nav)}  ({_pct(ret)})")
        print(f"  Cash:       {_money(acct['cash'])}")
        print(f"  Exposure:   {_money(exposure)} ({_pct(exposure / balance * 100 if balance else 0)} of balance)")
        print(f"  Realized:   {_money(realized)}")
        print(f"  Unrealized: {_money(unrealized)}")
        print(f"  Total P&L:  {_money(realized + unrealized)}")

        if acct["positions"]:
            for sym, pos in sorted(acct["positions"].items()):
                cp = pos.get("current_price", pos["avg_cost"])
                if pos["side"] == "long":
                    pl = (cp - pos["avg_cost"]) * pos["qty"]
                else:
                    pl = (pos["avg_cost"] - cp) * pos["qty"]
                print(f"    {sym:<8} {pos['qty']:>5} @ ${pos['avg_cost']:.2f} -> ${cp:.2f}  {_money(pl)}")
        print()

    if not acct_filter:
        combined = sum(a["balance"] for a in state["accounts"].values())
        total_ret = (total_nav - combined) / combined * 100 if combined else 0
        print(f"Total NAV: {_money(total_nav)} ({_pct(total_ret)})")
        if state.get("last_mark"):
            print(f"Last mark: {state['last_mark'][:19]}")


def cmd_compare(args):
    state = _state()
    spy_now = _quote("SPY")
    spy_inception = state.get("spy_inception_price")

    print("=== Account Comparison ===\n")
    print(f"  {'Account':<10} {'Name':<25} {'NAV':>12} {'Return':>8} {'Realized':>10} {'Unrealized':>10}")
    print(f"  {'-------':<10} {'----':<25} {'---':>12} {'---':>8} {'---':>10} {'---':>10}")

    for acct_id in ACCOUNT_IDS:
        if acct_id not in state["accounts"]:
            continue
        acct = state["accounts"][acct_id]
        exposure = _account_exposure(acct)
        nav = acct["cash"] + exposure
        balance = acct["balance"]
        ret = (nav - balance) / balance * 100 if balance else 0
        realized = acct.get("realized_pnl", 0)
        unrealized = sum(
            ((p.get("current_price", p["avg_cost"]) - p["avg_cost"]) * p["qty"]
             if p["side"] == "long"
             else (p["avg_cost"] - p.get("current_price", p["avg_cost"])) * p["qty"])
            for p in acct["positions"].values()
        )
        print(f"  {acct_id:<10} {acct['name']:<25} {_money(nav):>12} {_pct(ret):>8} {_money(realized):>10} {_money(unrealized):>10}")

    if spy_inception and spy_now:
        spy_ret = (spy_now - spy_inception) / spy_inception * 100
        print(f"\n  {'SPY':<10} {'Buy & hold benchmark':<25} {'':>12} {_pct(spy_ret):>8}")
        print(f"  (Inception ${spy_inception:.2f} -> Now ${spy_now:.2f})")

    print(f"\n  Inception: {state['inception']}")


def cmd_positions(args):
    state = _state()
    acct_filter = args[0].lower() if args else None
    found = False

    for acct_id in ACCOUNT_IDS:
        if acct_id not in state["accounts"]:
            continue
        acct = state["accounts"][acct_id]
        if acct_filter and acct_id != acct_filter:
            continue
        if not acct["positions"]:
            continue

        found = True
        balance = acct["balance"]
        print(f"=== {acct_id}: {acct['name']} ===")
        print(f"  {'Symbol':<8} {'Side':<5} {'Qty':>5} {'Avg':>10} {'Current':>10} {'P&L':>10} {'P&L%':>7} {'%Acct':>7}")
        print(f"  {'------':<8} {'----':<5} {'---':>5} {'---':>10} {'-------':>10} {'---':>10} {'----':>7} {'-----':>7}")

        for sym, pos in sorted(acct["positions"].items()):
            cp = pos.get("current_price", pos["avg_cost"])
            if pos["side"] == "long":
                pl = (cp - pos["avg_cost"]) * pos["qty"]
            else:
                pl = (pos["avg_cost"] - cp) * pos["qty"]
            cost = pos["avg_cost"] * pos["qty"]
            pl_pct = (pl / cost * 100) if cost else 0
            acct_pct = (pos["qty"] * cp) / balance * 100 if balance else 0
            print(f"  {sym:<8} {pos['side']:<5} {pos['qty']:>5} ${pos['avg_cost']:>9.2f} ${cp:>9.2f} {_money(pl):>10} {_pct(pl_pct):>7} {_pct(acct_pct):>7}")
        print()

    if not found:
        print("No open positions.")


def cmd_reconcile(args):
    state = _state()

    # Sum journal positions across all accounts
    journal_totals = {}
    for acct in state["accounts"].values():
        for sym, pos in acct["positions"].items():
            journal_totals.setdefault(sym, 0)
            if pos["side"] == "long":
                journal_totals[sym] += pos["qty"]
            else:
                journal_totals[sym] -= pos["qty"]

    # Fetch Tradier positions
    broker_raw = _tradier_positions()
    broker_totals = {}
    for p in broker_raw:
        sym = p["symbol"]
        qty = int(float(p["qty"]))
        side = p.get("side", "long")
        broker_totals[sym] = qty if side == "long" else -qty

    all_symbols = sorted(set(list(journal_totals.keys()) + list(broker_totals.keys())))

    if not all_symbols:
        print("No positions in journal or Tradier.")
        return

    mismatches = 0
    print(f"  {'Symbol':<8} {'Journal':>8} {'Tradier':>8} {'Status':<10}")
    print(f"  {'------':<8} {'-------':>8} {'-------':>8} {'------':<10}")

    for sym in all_symbols:
        jq = journal_totals.get(sym, 0)
        aq = broker_totals.get(sym, 0)
        ok = jq == aq
        if not ok:
            mismatches += 1
        status = "OK" if ok else "MISMATCH"
        print(f"  {sym:<8} {jq:>8} {aq:>8} {status}")

    print()
    if mismatches:
        print(f"  {mismatches} mismatch(es) — reconcile manually")
    else:
        print(f"  All positions match")


def cmd_halt(args):
    if len(args) < 2:
        _die("Usage: trade-journal halt <account> <reason>")

    state = _state()
    account = args[0].lower()
    reason = " ".join(args[1:])

    if account not in state["accounts"]:
        _die(f"Unknown account '{account}'. Use: {', '.join(ACCOUNT_IDS)}")

    state["accounts"][account]["halted"] = True
    state["accounts"][account]["halt_reason"] = reason
    _save(STATE_PATH, state)
    print(f"Account {account} halted: {reason}")


def cmd_unhalt(args):
    if not args:
        _die("Usage: trade-journal unhalt <account>")

    state = _state()
    account = args[0].lower()
    if account not in state["accounts"]:
        _die(f"Unknown account '{account}'. Use: {', '.join(ACCOUNT_IDS)}")

    state["accounts"][account]["halted"] = False
    state["accounts"][account]["halt_reason"] = None
    _save(STATE_PATH, state)
    print(f"Account {account} resumed.")


# --- Main ---

COMMANDS = {
    "init": cmd_init,
    "log": cmd_log,
    "close": cmd_close,
    "mark": cmd_mark,
    "summary": cmd_summary,
    "compare": cmd_compare,
    "positions": cmd_positions,
    "reconcile": cmd_reconcile,
    "halt": cmd_halt,
    "unhalt": cmd_unhalt,
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        print(__doc__.strip())
        sys.exit(0)

    cmd = sys.argv[1]
    if cmd not in COMMANDS:
        _die(f"Unknown command: {cmd}")

    COMMANDS[cmd](sys.argv[2:])


if __name__ == "__main__":
    main()
